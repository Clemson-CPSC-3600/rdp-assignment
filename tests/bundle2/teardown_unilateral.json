{
  "name": "teardown_unilateral",
  "category": "teardown",
  "bundle": 2,
  "points": 3,
  "description": "A sends data, then initiates unilateral close; both reach expected teardown states.",
  "config": {
    "timer_interval": 1.0,
    "window_size": 4096,
    "a_isn": 1000,
    "b_isn": 5000,
    "initial_sender": "A"
  },
  "events": [
    {"index": 0, "type": "handshake_complete"},
    {"index": 1, "type": "app_send", "host": "A", "payload": "hello"},
    {"index": 2, "type": "app_close", "host": "A"}
  ],
  "assertions": [
    {"after_event": 2, "host": "A", "check": "state == CLOSED"},
    {"after_event": 2, "host": "B", "check": "state == CLOSING"}
  ]
}

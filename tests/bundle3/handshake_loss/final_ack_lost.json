{
  "name": "final_ack_lost",
  "category": "handshake_loss",
  "bundle": 3,
  "points": 3,
  "description": "The final ACK from A (completing 3-way handshake) is dropped. A is already ESTABLISHED; B stays in SYN_RECEIVED. B's retransmit timer fires and retransmits SYN_ACK, but A (now ESTABLISHED) ignores it — B remains stuck in SYN_RECEIVED for the duration of the scenario.",
  "config": {
    "timer_interval": 1.0,
    "window_size": 4096,
    "a_isn": 1000,
    "b_isn": 5000,
    "initial_sender": "A"
  },
  "events": [
    {"index": 0, "type": "drop_next", "match": {"host": "A", "pkt_type": "ACK"}},
    {"index": 1, "type": "app_send", "host": "A", "payload": ""},
    {"index": 2, "t": 2.5, "type": "tick"}
  ],
  "assertions": [
    {"after_event": 2, "host": "A", "check": "state == ESTABLISHED"},
    {"after_event": 2, "host": "A", "check": "next_seq == 1001"},
    {"after_event": 2, "host": "A", "check": "window_base == 1001"},
    {"after_event": 2, "host": "B", "check": "state == SYN_RECEIVED"},
    {"after_event": 2, "host": "B", "check": "retransmit_count[5000] >= 1"}
  ]
}

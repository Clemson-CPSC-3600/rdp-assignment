{
  "name": "simultaneous_close",
  "category": "teardown_edge",
  "bundle": 3,
  "points": 3,
  "description": "Both sides call close sequentially; B traverses CLOSING then CLOSED, A traverses FIN_WAIT then CLOSED then CLOSING.",
  "config": {
    "timer_interval": 1.0,
    "window_size": 4096,
    "a_isn": 1000,
    "b_isn": 5000,
    "initial_sender": "A"
  },
  "events": [
    {"index": 0, "type": "handshake_complete"},
    {"index": 1, "type": "app_close", "host": "A"},
    {"index": 2, "type": "app_close", "host": "B"}
  ],
  "assertions": [
    {"after_event": 1, "host": "A", "check": "state == CLOSED"},
    {"after_event": 1, "host": "B", "check": "state == CLOSING"},
    {"after_event": 2, "host": "A", "check": "state == CLOSING"},
    {"after_event": 2, "host": "B", "check": "state == CLOSED"}
  ]
}
